# ============================================================================
# xAgriScan — .gitignore (Root)
# Full-stack: Python (Flask/PyTorch) + React (Vite) + Jupyter Notebooks
# ============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
ENV/
env/

# ---------------------------------------------------------------------------
# Node.js / React / Vite (frontend)
# ---------------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json

# ---------------------------------------------------------------------------
# Environment variables & secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
backend/.env

# ---------------------------------------------------------------------------
# Jupyter Notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Trained models (large binary files)
# ---------------------------------------------------------------------------
models/*.pth
models/*.pt
models/*.onnx
models/*.h5
models/*.pkl

# ---------------------------------------------------------------------------
# Datasets (large image folders — versioned separately or downloaded)
# ---------------------------------------------------------------------------
data/train/
data/val/
data/test/

# ---------------------------------------------------------------------------
# IDE & Editors
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.log
logs/
*.bak
*.tmp
*.swp
*~